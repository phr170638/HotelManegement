spring:
  datasource:
    username: root
    password: your_mysql_password
  redis:
    host: localhost
    port: 6379
    password:
  mail:
    host: smtp.qq.com
    port: 465
    username: your_qq_mail@qq.com
    password: your_mail_smtp_authorization_code
    protocol: smtp
    default-encoding: UTF-8
    properties:
      mail:
        smtp:
          auth: true
          ssl:
            enable: true
  rabbitmq:
    host: localhost
    port: 5672
    username: guest
    password: guest

jwt:
  secret: replace-with-a-32-byte-or-longer-secret
  expiration: 86400000

alipay:
  app-id: your_app_id
  private-key: |
    -----BEGIN PRIVATE KEY-----
    replace-with-your-private-key
    -----END PRIVATE KEY-----
  alipay-public-key: |
    -----BEGIN PUBLIC KEY-----
    replace-with-alipay-public-key
    -----END PUBLIC KEY-----
  gateway-url: https://openapi.alipaydev.com/gateway.do
  notify-url: http://localhost:8090/api/order/pay-notify
  return-url: http://localhost:5173/order/result

app:
  notification:
    mail:
      from-name: 酒店管理系统
